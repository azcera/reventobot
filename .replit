modules = ["nodejs-20"]

[[ports]]
localPort = 3000
externalPort = 3000

[nix]
packages = ["speech-tools"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"
waitForPort = 3000

[deployment]
build = ["sh", "-c", "npm install"]
run = ["node", "index.js"]
deploymentTarget = "vm"
